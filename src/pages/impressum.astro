---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
---

<Layout title="Impressum — ATESH Grill & Restaurant">
  <Navbar />

  <main class="bg-[#2C1D14] min-h-screen pt-32 pb-24 px-6">
    <div class="max-w-3xl mx-auto">

      <a href="/" class="text-[#C4953A] text-sm hover:underline mb-10 inline-block">
        ← Zurück zur Startseite
      </a>

      <h1 class="text-4xl font-bold text-[#F5F0EB] mb-3">Impressum</h1>
      <div class="gold-divider mb-10"></div>

      <div class="space-y-8 text-[#B8A99A] leading-relaxed">

        <div>
          <h2 class="text-[#C4953A] text-xs uppercase tracking-widest font-semibold mb-3">Angaben gemäß § 5 TMG</h2>
          <p class="text-[#F5F0EB]">ATESH Grill & Restaurant</p>
          <p>Vegesacker Straße 16-18</p>
          <p>28217 Bremen</p>
        </div>

        <div>
          <h2 class="text-[#C4953A] text-xs uppercase tracking-widest font-semibold mb-3">Kontakt</h2>
          <p>Telefon: <a href="tel:+4942117241862" class="text-[#F5F0EB] hover:text-[#C4953A] transition-colors">0421 17241862</a></p>
          <p>E-Mail: <span class="text-[#F5F0EB]">info@atesh-bremen.de</span></p>
        </div>

        <div>
          <h2 class="text-[#C4953A] text-xs uppercase tracking-widest font-semibold mb-3">Umsatzsteuer-ID</h2>
          <p>Umsatzsteuer-Identifikationsnummer gemäß § 27a UStG:<br />
          <span class="text-[#F5F0EB]">6023625642</span></p>
        </div>

        <div>
          <h2 class="text-[#C4953A] text-xs uppercase tracking-widest font-semibold mb-3">Verantwortlich für den Inhalt nach § 55 Abs. 2 RStV</h2>
          <p class="text-[#F5F0EB]">Vedat Karakaya</p>
          <p>Vegesacker Straße 16-18, 28217 Bremen</p>
        </div>

        <div>
          <h2 class="text-[#C4953A] text-xs uppercase tracking-widest font-semibold mb-3">Haftungsausschluss</h2>
          <p>Die Inhalte unserer Seiten wurden mit größter Sorgfalt erstellt. Für die Richtigkeit, Vollständigkeit
          und Aktualität der Inhalte können wir jedoch keine Gewähr übernehmen.</p>
        </div>

        <div>
          <h2 class="text-[#C4953A] text-xs uppercase tracking-widest font-semibold mb-3">Datenschutz</h2>
          <p>Unsere <a href="/datenschutz" class="text-[#C4953A] hover:underline">Datenschutzerklärung</a> finden Sie auf einer separaten Seite.</p>
        </div>

      </div>
    </div>
  </main>
</Layout>
