---
import '../styles/global.css';
import '@fontsource/dm-sans/300.css';
import CookieBanner from '../components/CookieBanner.astro';
import PromoPopup from '../components/PromoPopup.astro';
import '@fontsource/dm-sans/400.css';
import '@fontsource/dm-sans/500.css';
import '@fontsource/dm-sans/600.css';
import '@fontsource/playfair-display/400.css';
import '@fontsource/playfair-display/400-italic.css';
import '@fontsource/playfair-display/700.css';
import '@fontsource/playfair-display/700-italic.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'ATESH Grill & Restaurant', description = 'Modern Turkish · Steakhouse · Bremen. Vegesacker Straße 16-18, 28217 Bremen.' } = Astro.props;
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://atesh-bremen.de" />
    <meta name="theme-color" content="#1A110C" />

    <!-- Open Graph -->
    <meta property="og:type" content="restaurant" />
    <meta property="og:site_name" content="ATESH Grill & Restaurant" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://atesh-bremen.de" />
    <meta property="og:image" content="https://atesh-bremen.de/images/drausse_front.jpeg" />
    <meta property="og:image:width" content="1152" />
    <meta property="og:image:height" content="2048" />
    <meta property="og:locale" content="de_DE" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://atesh-bremen.de/images/drausse_front.jpeg" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- JSON-LD: Restaurant -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Restaurant",
      "name": "ATESH Grill & Restaurant",
      "description": "Authentische türkische Grillküche in Bremen-Vegesack. Modern Turkish · Steakhouse.",
      "url": "https://atesh-bremen.de",
      "telephone": "+4942117241862",
      "email": "info@atesh-bremen.de",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Vegesacker Straße 16-18",
        "addressLocality": "Bremen",
        "postalCode": "28217",
        "addressCountry": "DE"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 53.09597432437165,
        "longitude": 8.78587807651589
      },
      "openingHoursSpecification": [{
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
        "opens": "12:00",
        "closes": "00:00"
      }],
      "servesCuisine": ["Türkisch", "Steakhouse", "Grill"],
      "priceRange": "€€",
      "image": "https://atesh-bremen.de/images/drausse_front.jpeg",
      "sameAs": ["https://www.instagram.com/atesh.bremen/"]
    })} />
  </head>
  <body>
    <slot />
    <CookieBanner />
    <PromoPopup />

    <script>
      // Intersection Observer für scroll-reveal
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            const delay = el.dataset.delay ? parseInt(el.dataset.delay) : 0;
            setTimeout(() => {
              el.classList.add('visible');
            }, delay);
            observer.unobserve(el);
          }
        });
      }, { threshold: 0.12 });

      document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
    </script>
  </body>
</html>
