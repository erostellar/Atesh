---
const images = [
  { src: "/images/wein1.jpeg",  alt: "ATESH — Weinauswahl",  span: "span-col-2" },
  { src: "/images/innen1.jpeg", alt: "ATESH — Innenansicht", span: "span-row-2" },
  { src: "/images/innen2.jpeg", alt: "ATESH — Innenansicht", span: "" },
  { src: "/images/innen3.jpeg", alt: "ATESH — Innenansicht", span: "" },
  { src: "/images/innen4.jpeg", alt: "ATESH — Innenansicht", span: "" },
  { src: "/images/innen5.jpeg", alt: "ATESH — Innenansicht", span: "" },
  { src: "/images/karte2.jpeg", alt: "ATESH — Speisekarte",  span: "" },
  { src: "/images/wein2.jpeg",  alt: "ATESH — Wein",         span: "span-col-2" },
  { src: "/images/bar.jpeg",    alt: "ATESH — Bar",          span: "" },
];
---

<section id="gallery" class="bg-[#2C1D14] py-24 px-6">
  <div class="max-w-6xl mx-auto">

    <!-- Header -->
    <div class="text-center reveal">
      <p class="section-label">Einblicke</p>
      <h2 class="mt-3 text-3xl md:text-4xl font-bold text-[#F5F0EB]">Unser Restaurant</h2>
      <div class="gold-divider centered"></div>
    </div>

    <!-- Grid -->
    <div class="mt-12 gallery-grid">
      {images.map((img, i) => (
        <button
          class={`gallery-item reveal lightbox-trigger ${img.span}`}
          data-delay={i * 100}
          data-src={img.src}
          data-caption={img.alt}
          aria-label={img.alt + ' vergrößern'}
        >
          <img src={img.src} alt={img.alt} loading="lazy" />
          <div class="gallery-overlay">
            <svg class="gallery-zoom-icon" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"/>
            </svg>
          </div>
        </button>
      ))}
    </div>

  </div>
</section>

<!-- Lightbox (shared, only one instance needed) -->
<div id="gallery-lightbox" class="g-lightbox" role="dialog" aria-modal="true">
  <button id="g-lightbox-close" class="g-lightbox-close" aria-label="Schließen">
    <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
    </svg>
  </button>
  <div class="g-lightbox-inner">
    <img id="g-lightbox-img" src="" alt="" class="g-lightbox-image" />
    <p id="g-lightbox-caption" class="g-lightbox-caption"></p>
  </div>
</div>

<style>
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }
  .gallery-item {
    position: relative;
    overflow: hidden;
    border-radius: 2px;
    aspect-ratio: 4/3;
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
  }
  .gallery-item.span-col-2 { grid-column: span 2; }
  .gallery-item.span-row-2 { grid-row: span 2; aspect-ratio: unset; }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
    display: block;
  }
  .gallery-overlay {
    position: absolute;
    inset: 0;
    background: rgba(196, 149, 58, 0);
    transition: background 0.35s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .gallery-zoom-icon {
    width: 36px;
    height: 36px;
    color: white;
    opacity: 0;
    transform: scale(0.8);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .gallery-item:hover img { transform: scale(1.05); }
  .gallery-item:hover .gallery-overlay { background: rgba(26, 17, 12, 0.45); }
  .gallery-item:hover .gallery-zoom-icon { opacity: 1; transform: scale(1); }

  /* Lightbox */
  .g-lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(10, 6, 4, 0.96);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
    backdrop-filter: blur(10px);
  }
  .g-lightbox.open {
    opacity: 1;
    pointer-events: all;
  }
  .g-lightbox-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    padding: 24px;
  }
  .g-lightbox-image {
    max-width: min(900px, 90vw);
    max-height: 80vh;
    object-fit: contain;
    border-radius: 2px;
    box-shadow: 0 0 100px rgba(196, 149, 58, 0.12);
    transform: scale(0.93);
    transition: transform 0.35s ease;
  }
  .g-lightbox.open .g-lightbox-image { transform: scale(1); }
  .g-lightbox-caption {
    font-family: 'Playfair Display', serif;
    font-size: 0.95rem;
    color: #B8A99A;
    letter-spacing: 0.04em;
    text-align: center;
  }
  .g-lightbox-close {
    position: fixed;
    top: 20px;
    right: 24px;
    color: #B8A99A;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 50%;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: color 0.2s, background 0.2s;
    z-index: 1001;
  }
  .g-lightbox-close:hover {
    color: #C4953A;
    background: rgba(196, 149, 58, 0.1);
  }

  @media (max-width: 768px) {
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
    .gallery-item.span-col-2,
    .gallery-item.span-row-2 { grid-column: unset; grid-row: unset; aspect-ratio: 4/3; }
  }
</style>

<script>
  const lb     = document.getElementById('gallery-lightbox')!;
  const lbImg  = document.getElementById('g-lightbox-img') as HTMLImageElement;
  const lbCap  = document.getElementById('g-lightbox-caption')!;
  const lbClose= document.getElementById('g-lightbox-close')!;

  function openLb(src: string, caption: string) {
    lbImg.src = src;
    lbImg.alt = caption;
    lbCap.textContent = caption;
    lb.classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function closeLb() {
    lb.classList.remove('open');
    document.body.style.overflow = '';
  }

  document.querySelectorAll('#gallery .lightbox-trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      openLb(
        (btn as HTMLElement).dataset.src || '',
        (btn as HTMLElement).dataset.caption || ''
      );
    });
  });

  lbClose.addEventListener('click', closeLb);
  lb.addEventListener('click', e => { if (e.target === lb) closeLb(); });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLb(); });
</script>
