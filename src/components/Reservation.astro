---
---

<section id="reservation" class="relative bg-[#1A110C] py-28 px-6 overflow-hidden">
  <!-- Background image dimmed -->
  <div class="absolute inset-0 bg-cover bg-center opacity-10"
    style="background-image: url('/images/innen-dunkel.jpeg'); filter: blur(4px);"></div>
  <div class="absolute inset-0 bg-[#1A110C]/80"></div>

  <!-- Decorative gold lines -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#C4953A]/40 to-transparent"></div>
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#C4953A]/40 to-transparent"></div>

  <div class="relative max-w-4xl mx-auto">

    <!-- Header -->
    <div class="text-center reveal">
      <p class="section-label">Reservierung</p>
      <h2 class="mt-3 text-3xl md:text-4xl font-bold text-[#F5F0EB]">Ihr Tisch wartet</h2>
      <div class="gold-divider centered"></div>
      <p class="mt-4 text-[#B8A99A] text-sm leading-relaxed max-w-md mx-auto">
        Rufen Sie uns einfach an — wir reservieren Ihren Tisch persönlich und unkompliziert.
      </p>
    </div>

    <!-- Phone CTA -->
    <div class="mt-14 text-center reveal">
      <p class="text-xs uppercase tracking-widest mb-4" style="color: #C0272D;">Jetzt reservieren</p>
      <a href="tel:+4942117241862"
        class="inline-flex items-center gap-3 group">
        <span class="phone-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.8
              a19.79 19.79 0 01-3.07-8.64A2 2 0 012 1h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2
              2 0 01-.45 2.11L6.91 8.67a16 16 0 006.35 6.35l1.27-1.27a2 2 0 012.11-.45
              c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
          </svg>
        </span>
        <span class="num text-[#C4953A] text-4xl md:text-5xl font-bold tracking-wide
          group-hover:text-[#d4a84a] transition-colors duration-300"
          style="text-shadow: 0 0 40px rgba(196,149,58,0.35);">
          0421 17241862
        </span>
      </a>
    </div>

    <!-- Divider -->
    <div class="mt-16 mb-14 flex items-center gap-6 reveal">
      <div class="flex-1 h-px bg-gradient-to-r from-transparent to-[#4A3728]"></div>
      <div class="w-1.5 h-1.5 rotate-45 bg-[#C4953A] opacity-60"></div>
      <div class="flex-1 h-px bg-gradient-to-l from-transparent to-[#4A3728]"></div>
    </div>

    <!-- Info cards -->
    <div class="grid md:grid-cols-2 gap-8 reveal" data-delay="100">

      <!-- Adresse -->
      <div class="info-card group">
        <div class="info-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0118 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
        </div>
        <div>
          <p class="text-xs uppercase tracking-widest text-[#C4953A] mb-3">Adresse</p>
          <p class="text-[#F5F0EB] text-lg font-medium leading-relaxed">
            Vegesacker Straße 16-18
          </p>
          <p class="text-[#B8A99A] mt-1">28217 Bremen</p>
          <a href="https://maps.google.com/?q=Vegesacker+Straße+16-18+28217+Bremen"
            target="_blank" rel="noopener"
            class="inline-block mt-4 text-xs uppercase tracking-widest text-[#C4953A]/70
              hover:text-[#C4953A] transition-colors duration-300 border-b border-[#C4953A]/30
              hover:border-[#C4953A] pb-0.5">
            In Maps öffnen →
          </a>
        </div>
      </div>

      <!-- Öffnungszeiten -->
      <div class="info-card group">
        <div class="info-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
        </div>
        <div>
          <p class="text-xs uppercase tracking-widest text-[#C4953A] mb-3">Öffnungszeiten</p>
          <div class="space-y-2">
            <div class="flex justify-between items-baseline gap-8">
              <span class="text-[#B8A99A] text-sm">Montag bis Sonntag</span>
              <span class="text-[#F5F0EB] font-medium tabular-nums">12:00 - 00:00</span>
            </div>
            <div class="h-px bg-[#4A3728]/50"></div>
            <p class="text-[#B8A99A] text-xs italic pt-1">Täglich für Sie geöffnet</p>
          </div>
        </div>
      </div>

    </div>

  </div>
</section>

<style>
  .info-card {
    background: linear-gradient(135deg, #2A1D15 0%, #221710 100%);
    border: 1px solid #4A3728;
    padding: 2rem;
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    transition: border-color 0.3s;
  }
  .info-card:hover {
    border-color: #C4953A;
  }
  .info-icon {
    color: #C4953A;
    opacity: 0.8;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .phone-icon {
    color: #C4953A;
    opacity: 0.7;
    transition: opacity 0.3s;
  }
  a:hover .phone-icon {
    opacity: 1;
  }
</style>
