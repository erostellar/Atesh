---
---

<!-- Maps -->
<div class="w-full h-[300px] overflow-hidden maps-wrapper">
  <div
    class="maps-placeholder"
    style="width:100%;height:300px;"
    data-src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2390.4!2d8.7763!3d53.1065!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2sVegesacker+Stra%C3%9Fe+16-18%2C+28217+Bremen!5e0!3m2!1sde!2sde!4v1234567890"
    data-filter="grayscale(0.4) brightness(0.7)"
  >
    <div style="width:100%;height:300px;background:#1A110C;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:0.75rem;cursor:pointer;border-top:1px solid #4A3728;">
      <svg width="28" height="28" fill="none" stroke="#C4953A" stroke-width="1.5" viewBox="0 0 24 24">
        <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>
      </svg>
      <p style="font-family:'DM Sans',sans-serif;font-size:0.75rem;color:#B8A99A;letter-spacing:0.1em;text-transform:uppercase;margin:0;">Karte laden</p>
      <p style="font-family:'DM Sans',sans-serif;font-size:0.65rem;color:#4A3728;margin:0;">Google Maps — Klicken zum Aktivieren</p>
    </div>
  </div>
</div>

<footer class="bg-[#140D08] px-6 pt-16 pb-8">
  <!-- Gold top border -->
  <div class="max-w-6xl mx-auto border-t border-[#C4953A]/20 mb-14"></div>

  <div class="max-w-6xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-10 mb-14">

    <!-- Branding -->
    <div class="col-span-2 md:col-span-1">
      <img src="/images/logo.png" alt="ATESH Grill & Restaurant" class="h-12 w-auto mb-2" />
      <p class="text-[#B8A99A] text-xs tracking-wider mt-1">Modern Turkish · Steakhouse · Bremen</p>

      <!-- Social -->
      <div class="flex gap-4 mt-6">
        <a href="https://www.instagram.com/atesh.bremen/" target="_blank" rel="noopener" aria-label="Instagram" class="social-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <circle cx="12" cy="12" r="4"/>
            <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Navigation -->
    <div>
      <p class="footer-heading">Navigation</p>
      <ul class="mt-4 space-y-3">
        <li><a href="#about" class="footer-link">Über uns</a></li>
        <li><a href="#menu" class="footer-link">Speisekarte</a></li>
        <li><a href="#gallery" class="footer-link">Galerie</a></li>
        <li><a href="#reservation" class="footer-link">Reservieren</a></li>
        <li><a href="/impressum" class="footer-link">Impressum</a></li>
      </ul>
    </div>

    <!-- Kontakt -->
    <div>
      <p class="footer-heading">Kontakt</p>
      <ul class="mt-4 space-y-3 text-[#B8A99A] text-sm">
        <li class="flex gap-2 items-start">
          <svg class="mt-0.5 shrink-0" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          <span>Vegesacker Straße 16-18<br />28217 Bremen</span>
        </li>
        <li class="flex gap-2 items-center">
          <svg class="shrink-0" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.99 7 19.79 19.79 0 0 1 2 2.18 2 2 0 0 1 4 0h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 7.91a16 16 0 0 0 7.73 7.73l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          <a href="tel:+4942117241862" class="hover:text-[#C4953A] transition-colors">0421 17241862</a>
        </li>
        <li class="flex gap-2 items-center">
          <svg class="shrink-0" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          <span>info@atesh-bremen.de</span>
        </li>
      </ul>
    </div>

    <!-- Öffnungszeiten -->
    <div>
      <p class="footer-heading">Öffnungszeiten</p>
      <div class="mt-4 space-y-2 text-[#B8A99A] text-sm">
        <p>Montag bis Sonntag</p>
        <p class="text-[#C4953A] font-semibold">12:00 - 00:00 Uhr</p>
      </div>
    </div>

  </div>

  <!-- Copyright -->
  <div class="max-w-6xl mx-auto border-t border-[#4A3728] pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
    <p class="text-[#B8A99A] text-xs">© 2026 ATESH Grill & Restaurant. Alle Rechte vorbehalten.</p>
    <div class="flex gap-6">
      <a href="/impressum" class="text-[#B8A99A] text-xs hover:text-[#C4953A] transition-colors">Impressum</a>
      <a href="/datenschutz" class="text-[#B8A99A] text-xs hover:text-[#C4953A] transition-colors">Datenschutz</a>
    </div>
  </div>
</footer>

<style>
  .footer-heading {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #C4953A;
  }
  .footer-link {
    display: block;
    font-size: 0.875rem;
    color: #B8A99A;
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-link:hover {
    color: #C4953A;
  }
  .social-icon {
    color: #B8A99A;
    transition: color 0.2s;
  }
  .social-icon:hover {
    color: #C4953A;
  }
</style>
