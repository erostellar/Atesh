---
---

<!-- Floating trigger button -->
<button id="promo-trigger" class="promo-trigger" aria-label="Angebot anzeigen">
  <span class="promo-trigger-icon">%</span>
</button>

<!-- Popup overlay -->
<div id="promo-overlay" class="promo-overlay" role="dialog" aria-modal="true" aria-label="Aktuelle Promotion">
  <div class="promo-modal">

    <button id="promo-close" class="promo-close" aria-label="Schließen">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
        <path d="M1 1l14 14M15 1L1 15"/>
      </svg>
    </button>

    <p class="promo-label">Exklusives Angebot</p>

    <div class="promo-amount-wrap">
      <span class="promo-amount">3 × 10€</span>
      <span class="promo-amount-sub">Rabatt auf deine nächsten 3 Bestellungen</span>
    </div>

    <div class="promo-divider"></div>

    <p class="promo-body">
      Gib beim Bezahlen unter <em>„Rabattcode eingeben"</em> einfach folgenden Code ein:
    </p>

    <div class="promo-code-box" id="promo-code-box" title="Klicken zum Kopieren">
      <span class="promo-code">ATESH</span>
      <span class="promo-copy-hint" id="promo-copy-hint">Kopieren</span>
    </div>

    <a
      href="https://ateshgrillrestaurant.online-karte.com/ateshgrillrestaurant"
      target="_blank"
      rel="noopener noreferrer"
      class="promo-cta"
    >
      Jetzt Online Bestellen
    </a>

    <button id="promo-skip" class="promo-skip">Kein Interesse</button>

  </div>
</div>

<style>
  /* ── Floating trigger ── */
  .promo-trigger {
    position: fixed;
    bottom: 1.75rem;
    right: 1.75rem;
    z-index: 9997;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: #C41E24;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 20px rgba(196, 30, 36, 0.5);
    opacity: 0;
    transform: scale(0.6);
    transition: opacity 0.3s ease, transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.2s;
    pointer-events: none;
  }
  .promo-trigger.visible {
    opacity: 1;
    transform: scale(1);
    pointer-events: all;
  }
  .promo-trigger.hidden {
    opacity: 0;
    transform: scale(0.6);
    pointer-events: none;
  }
  .promo-trigger:hover {
    box-shadow: 0 6px 28px rgba(196, 30, 36, 0.7);
    transform: scale(1.08);
  }
  .promo-trigger-icon {
    font-family: 'Playfair Display', serif;
    font-size: 1.4rem;
    font-weight: 700;
    font-style: italic;
    color: #F5F0EB;
    line-height: 1;
    pointer-events: none;
  }


  /* ── Overlay ── */
  .promo-overlay {
    position: fixed;
    inset: 0;
    z-index: 9998;
    background: rgba(10, 6, 3, 0.82);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }
  .promo-overlay.visible {
    opacity: 1;
    pointer-events: all;
  }

  /* ── Modal ── */
  .promo-modal {
    position: relative;
    background: #140D08;
    border: 1px solid #C4953A44;
    max-width: 420px;
    width: 100%;
    padding: 2.5rem 2rem 2rem;
    text-align: center;
    transform: scale(0.92) translateY(12px);
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow:
      0 0 0 1px #C4953A22,
      0 24px 80px rgba(0,0,0,0.7),
      inset 0 1px 0 #C4953A33;
  }
  .promo-overlay.visible .promo-modal {
    transform: scale(1) translateY(0);
  }
  .promo-modal::before {
    content: '';
    position: absolute;
    top: 0;
    left: 2rem;
    right: 2rem;
    height: 2px;
    background: linear-gradient(90deg, transparent, #C4953A, transparent);
  }

  .promo-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: transparent;
    border: 1px solid #4A3728;
    color: #B8A99A;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
    padding: 0;
  }
  .promo-close:hover {
    border-color: #B8A99A;
    color: #F5F0EB;
  }

  .promo-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #C4953A;
    margin: 0 0 1.25rem;
  }

  .promo-amount-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }
  .promo-amount {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(2.6rem, 12vw, 3.5rem);
    font-weight: 700;
    color: #C41E24;
    line-height: 1;
    letter-spacing: -0.01em;
  }
  .promo-amount-sub {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.88rem;
    font-weight: 400;
    color: #B8A99A;
    letter-spacing: 0.02em;
  }

  .promo-divider {
    width: 40px;
    height: 1px;
    background: #C4953A66;
    margin: 0 auto 1.5rem;
  }

  .promo-body {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.82rem;
    color: #B8A99A;
    line-height: 1.65;
    margin: 0 0 1.25rem;
  }
  .promo-body em {
    color: #F5F0EB;
    font-style: normal;
  }

  .promo-code-box {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    border: 1px dashed #C41E2466;
    background: #C41E2410;
    padding: 0.85rem 1.25rem;
    margin: 0 0 1.5rem;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
    user-select: none;
  }
  .promo-code-box:hover {
    border-color: #C41E24;
    background: #C41E2420;
  }
  .promo-code {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    color: #C41E24;
  }
  .promo-copy-hint {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #B8A99A;
    border: 1px solid #4A3728;
    padding: 0.2rem 0.5rem;
    transition: color 0.2s, border-color 0.2s;
  }
  .promo-code-box:hover .promo-copy-hint {
    color: #F5F0EB;
    border-color: #C41E2466;
  }

  .promo-cta {
    display: block;
    width: 100%;
    background: #C41E24;
    border: 1px solid #C41E24;
    color: #F5F0EB;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 1rem;
    transition: background 0.25s, border-color 0.25s;
    margin-bottom: 1rem;
  }
  .promo-cta:hover {
    background: #a51920;
    border-color: #a51920;
  }

  .promo-skip {
    background: transparent;
    border: none;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.72rem;
    color: #4A3728;
    letter-spacing: 0.08em;
    cursor: pointer;
    padding: 0.25rem;
    transition: color 0.2s;
  }
  .promo-skip:hover {
    color: #B8A99A;
  }

  @media (max-width: 480px) {
    .promo-modal {
      padding: 2rem 1.25rem 1.5rem;
      margin: 0.5rem;
    }
    .promo-trigger {
      bottom: 1.25rem;
      right: 1.25rem;
    }
  }
</style>

<script>
  const STORAGE_KEY = 'promo-atesh-v1';
  const overlay = document.getElementById('promo-overlay');
  const trigger = document.getElementById('promo-trigger');

  function openPopup() {
    overlay?.classList.add('visible');
    trigger?.classList.add('hidden');
  }

  function dismiss() {
    overlay?.classList.remove('visible');
    localStorage.setItem(STORAGE_KEY, 'dismissed');
    // Show trigger button after closing
    setTimeout(() => trigger?.classList.remove('hidden'), 300);
  }

  // Auto-show on first visit
  if (!localStorage.getItem(STORAGE_KEY)) {
    const cookieConsent = localStorage.getItem('maps-consent');
    const delay = cookieConsent ? 3000 : 6000;
    setTimeout(openPopup, delay);
  }

  // Trigger button always appears after a short delay
  setTimeout(() => {
    if (!overlay?.classList.contains('visible')) {
      trigger?.classList.add('visible');
    }
  }, 1500);

  trigger?.addEventListener('click', () => {
    trigger.classList.add('hidden');
    openPopup();
  });

  document.getElementById('promo-close')?.addEventListener('click', dismiss);
  document.getElementById('promo-skip')?.addEventListener('click', dismiss);

  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) dismiss();
  });

  // Copy code to clipboard
  document.getElementById('promo-code-box')?.addEventListener('click', () => {
    navigator.clipboard.writeText('ATESH').then(() => {
      const hint = document.getElementById('promo-copy-hint');
      if (hint) {
        hint.textContent = 'Kopiert ✓';
        hint.style.color = '#C41E24';
        hint.style.borderColor = '#C41E24';
        setTimeout(() => {
          hint.textContent = 'Kopieren';
          hint.style.color = '';
          hint.style.borderColor = '';
        }, 2000);
      }
    });
  });
</script>
